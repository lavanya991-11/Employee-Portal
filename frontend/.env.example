# Base URL of the backend API (include the /api suffix).
# Local development can leave this unset — the app falls back to http://localhost:3000/api.
# In production (e.g. Vercel), set this to your deployed backend, for example:
# VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=http://localhost:3000/api
