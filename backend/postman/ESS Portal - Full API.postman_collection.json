{
  "info": {
    "name": "ESS Portal - Full API",
    "description": "All GET/POST/PATCH endpoints of the Employee Self-Service portal.\n\nSet {{baseUrl}} and log in via Auth > Login, then copy the accessToken into the {{token}} collection variable. Protected requests use Bearer {{token}} automatically.",
