{
  "info": {
    "name": "ESS - Travel Requests",
    "description": "Portal travel (earning) request APIs: login, list earning pay codes, submit to Business Central via SubmitEarningRequest, list mine/all, and update (status/approvedBy/approvedDate/transactionNo) by Request No. Set the {{portalUrl}} variable to your backend (local: http://localhost:3000/api). The {{token}} is auto-filled by the Login request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "portalUrl", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "requestNo", "value": "ER000004", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Login (get token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var json = pm.response.json();",
              "if (json && json.accessToken) {",
              "    pm.collectionVariables.set('token', json.accessToken);",
              "    console.log('token saved');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{portalUrl}}/auth/login",
          "host": ["{{portalUrl}}"],
          "path": ["auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"vishwanath@novasoft.global\",\n  \"password\": \"<your-password>\"\n}"
        }
      }
    },
    {
      "name": "2. Earning Pay Codes (dropdown source)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/travel-requests/earning-paycodes",
          "host": ["{{portalUrl}}"],
          "path": ["travel-requests", "earning-paycodes"]
        }
      }
    },
    {
      "name": "3. Submit Travel Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/travel-requests",
          "host": ["{{portalUrl}}"],
          "path": ["travel-requests"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comments\": \"Annual air ticket\",\n  \"lines\": [\n    { \"earningPayCode\": 18, \"earningPayCodeDesc\": \"Air Ticket\", \"amount\": 1500, \"unitCount\": 1, \"earningDate\": \"2026-06-30\" }\n  ],\n  \"attachments\": [\n    { \"fileName\": \"ticket.pdf\", \"mimeType\": \"application/pdf\", \"contentBase64\": \"JVBERi0xLjQK\" }\n  ]\n}"
        }
      }
    },
    {
      "name": "4. My Travel Requests",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/travel-requests/my",
          "host": ["{{portalUrl}}"],
          "path": ["travel-requests", "my"]
        }
      }
    },
    {
      "name": "5. All Travel Requests",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/travel-requests/all",
          "host": ["{{portalUrl}}"],
          "path": ["travel-requests", "all"]
        }
      }
    },
    {
      "name": "6. Update by Request No (status / approvedBy / approvedDate / transactionNo)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/travel-requests/by-ref/{{requestNo}}",
          "host": ["{{portalUrl}}"],
          "path": ["travel-requests", "by-ref", "{{requestNo}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Approved\",\n  \"transactionNo\": \"TRX-000123\",\n  \"approvedBy\": \"Mohd Riyaz Uddin\",\n  \"approvedDate\": \"2026-06-25\",\n  \"comments\": \"Approved by reporting manager\"\n}"
        }
      }
    }
  ]
}
