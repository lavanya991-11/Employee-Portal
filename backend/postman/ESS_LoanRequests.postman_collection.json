{
  "info": {
    "name": "ESS - Loan Requests",
    "description": "Portal loan-request APIs: login, submit, list mine, and update (status/comments/approvedBy) by Request No. Set the {{portalUrl}} variable to your backend (local: http://localhost:3000/api). The {{token}} is auto-filled by the Login request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "portalUrl", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "requestNo", "value": "LR000006", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Login (get token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var json = pm.response.json();",
              "if (json && json.accessToken) {",
              "    pm.collectionVariables.set('token', json.accessToken);",
              "    console.log('token saved');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{portalUrl}}/auth/login",
          "host": ["{{portalUrl}}"],
          "path": ["auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"vishwanath@novasoft.global\",\n  \"password\": \"<your-password>\"\n}"
        }
      }
    },
    {
      "name": "2. Submit Loan Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/loan-requests",
          "host": ["{{portalUrl}}"],
          "path": ["loan-requests"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeCode\": \"1100\",\n  \"loanPayCode\": 12,\n  \"loanAmount\": 12000,\n  \"installmentCalculation\": 0,\n  \"noOfInstallments\": 12,\n  \"comments\": \"Home renovation\"\n}"
        }
      }
    },
    {
      "name": "3. My Loan Requests",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/loan-requests/my",
          "host": ["{{portalUrl}}"],
          "path": ["loan-requests", "my"]
        }
      }
    },
    {
      "name": "4. Update by Request No (status / comments / approvedBy)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{portalUrl}}/loan-requests/by-ref/{{requestNo}}",
          "host": ["{{portalUrl}}"],
          "path": ["loan-requests", "by-ref", "{{requestNo}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Approved\",\n  \"comments\": \"Approved by manager\",\n  \"approvedBy\": \"Vishwanath\"\n}"
        }
      }
    }
  ]
}
