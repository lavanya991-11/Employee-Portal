    {
      "name": "Auth",
      "item": [
        {
          "name": "POST create-super-admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Super Admin\",\n  \"email\": \"admin@ess.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/create-super-admin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "create-super-admin"]
            }
          }
        },
        {
          "name": "POST login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "    console.log('Tokens saved to collection variables');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ess.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "POST get-register-token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.registerToken) {",
                  "    pm.collectionVariables.set('registerToken', json.registerToken);",
                  "    console.log('Saved registerToken');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/get-register-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "get-register-token"]
            }
          }
        },
        {
          "name": "POST register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-register-token", "value": "{{registerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@ess.com\",\n  \"password\": \"Pass@123\",\n  \"empId\": \"EMP001\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Developer\",\n  \"role\": \"employee\",\n  \"employeeInfo\": {\n    \"employeeCode\": \"1001\",\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"gender\": \"Male\",\n    \"jobTitle\": \"Developer\",\n    \"status\": \"Active\",\n    \"department\": \"Engineering\",\n    \"designation\": \"Developer\",\n    \"dateOfJoining\": \"2026-01-01\",\n    \"currency\": \"AED\",\n    \"administration\": {\n      \"employmentType\": \"Employee\",\n      \"birthDate\": \"1988-06-26\",\n      \"maritalStatus\": \"Married\",\n      \"nationality\": \"JO\",\n      \"nationalityName\": \"Jordan\",\n      \"language\": \"ENG\",\n      \"languageName\": \"ENGLISH\",\n      \"address\": \"Dubai_U.A.E\",\n      \"city\": \"Dubai\",\n      \"email\": \"qusai@example.com\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "POST refresh-token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "    console.log('Access token refreshed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh-token"]
            }
          }
        },
        {
          "name": "POST verify-token",
          "request": {
            "method": "POST",
